{
  "permissions": {
    "allow": [
      "Bash(dart format:*)",
      "Bash(flutter analyze:*)",
      "Bash(dart run build_runner:*)",
      "Bash(flutter test:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; [ -n \"$f\" ] && echo \"$f\" | grep -qE '\\.dart$' && dart format \"$f\"; } 2>/dev/null || true",
            "statusMessage": "dart format..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "flutter analyze --no-fatal-infos 2>&1 | tail -3",
            "statusMessage": "flutter analyze...",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
